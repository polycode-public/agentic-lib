{
  "name": "@polycode-public/agentic-lib",
  "version": "8.2.0",
  "description": "The intentïon delivery engine — a thin wrapper over claude -p + Bedrock that runs one whole transformation per trigger and opens a draft PR.",
  "type": "module",
  "scripts": {
    "build": "echo \"Nothing to build\"",
    "formatting": "prettier --check '**/*.{js,json,yml,md}'",
    "formatting-fix": "prettier --write '**/*.{js,json,yml,md}'",
    "linting": "eslint",
    "linting-fix": "eslint --fix",
    "lint:workflows": "node scripts/validate-workflows.js",
    "security": "npm audit --audit-level=high",
    "test": "vitest --run",
    "start": "echo \"agentic-lib is a workflow SDK — see README.md\""
  },
  "keywords": [],
  "author": "https://github.com/polycode-public",
  "license": "(AGPL-3.0-only OR MIT)",
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "js-yaml": "^4.2.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "agentic-lib": "bin/agentic-lib.js"
  },
  "exports": {
    ".": "./bin/agentic-lib.js"
  },
  "files": [
    "package.json",
    "bin/",
    ".github/workflows/transform.yml",
    "components/",
    "missions/",
    "seeds/",
    "scripts/",
    "MODELS.md",
    "LICENSE",
    "LICENSE-MIT"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polycode-public/agentic-lib.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "smol-toml": "^1.6.1"
  }
}
